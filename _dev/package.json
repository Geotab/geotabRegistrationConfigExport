{
  "name": "RegistrationConfig",
  "version": "0.0.1",
  "description": "Tool for exporting default registration config in JSON file",
  "engines": {
    "node": ">=4.0.0"
  },
  "scripts": {
    "startServer": "node ../../../start.js",
    "build": "esbuild sources/addin.ts --bundle --platform=browser --outfile=../addin.js",
    "watch": "esbuild sources/addin.ts --bundle --platform=browser --outfile=../addin.js --watch",
    "start": "npm run startServer & npm run watch"
  },
  "devDependencies": {
    "esbuild": "^0.25.2",
    "typescript": "^5.9.3"
  }
}
